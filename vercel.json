{
    "version": 2,
    "name": "krishi-route",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/server.js"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/frontend/build/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/build/$1",
            "continue": true
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/build/index.html"
        }
    ]
}